# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Força um deployment target mínimo consistente em todos os pods.
      # Alguns plugins trazem valores antigos (9.0/10.0/11.0) que o Xcode/SDK
      # mais novo não suporta mais para o simulador (erro: unsupported option '-G').
      if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 13.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      end
    end

    # Corrige o erro "unsupported option '-G' for target ...".
    # A causa real: o BoringSSL-GRPC (dependência transitiva do Firebase/gRPC)
    # injeta a flag inválida "-GCC_WARN_INHIBIT_ALL_WARNINGS" em COMPILER_FLAGS
    # de cada arquivo-fonte. O Clang de Xcodes mais novos não reconhece essa
    # flag e a interpreta como "-G", travando o build. Removemos a flag aqui.
    if target.respond_to?(:source_build_phase) && target.source_build_phase
      target.source_build_phase.files.each do |file|
        if file.settings && file.settings['COMPILER_FLAGS']
          flags = file.settings['COMPILER_FLAGS'].split(' ')
          flags.reject! { |flag| flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS' }
          file.settings['COMPILER_FLAGS'] = flags.join(' ')
        end
      end
    end
  end

  # Corrige o erro "Parse Issue (Xcode): A template argument list is expected
  # after a name prefixed by the template keyword" em basic_seq.h do gRPC-Core.
  # Código antigo do gRPC (dependência transitiva do Firebase) não compila com
  # o Clang de Xcodes mais novos por falta de "<>" explícito. Faz o patch
  # automaticamente a cada `pod install`, já que o arquivo é baixado de novo
  # sempre que os Pods são reinstalados.
  basic_seq_path = File.join(__dir__, 'Pods', 'gRPC-Core', 'src', 'core', 'lib', 'promise', 'detail', 'basic_seq.h')
  if File.exist?(basic_seq_path)
    content = File.read(basic_seq_path)
    patched = content.gsub(
      'Traits::template CallSeqFactory(f_, *cur_, std::move(arg))',
      'Traits::template CallSeqFactory<>(f_, *cur_, std::move(arg))'
    )
    File.write(basic_seq_path, patched) if patched != content
  end
end
